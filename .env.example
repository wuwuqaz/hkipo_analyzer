# === 外部 API 配置 ===
# Tavily Search API Key（用于博主观点搜索）
# 获取地址: https://tavily.com/
TAVILY_API_KEY=

# LLM API 配置（用于博主观点分析）
# 支持 OpenAI 兼容接口，如 OpenRouter、SiliconFlow、阿里云等
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# === API 服务配置（可选）===
STORAGE_BASE_PATH=storage
MAX_CONCURRENT_ANALYSES=2
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 默认关闭 API token，适合本地/内网使用；公开部署时改为 true 并设置 HKIPO_API_TOKEN
HKIPO_REQUIRE_API_TOKEN=false
# 写接口、任务结果和报告下载的 Bearer token（仅 HKIPO_REQUIRE_API_TOKEN=true 时需要）
HKIPO_API_TOKEN=
# Next.js 服务端请求 API 时使用；通常与 HKIPO_API_TOKEN 相同
INTERNAL_API_TOKEN=
# 浏览器直连 FastAPI 时使用；只适合个人/内网部署，公网建议使用 nginx/平台认证
NEXT_PUBLIC_API_TOKEN=
